{
  "theme": "dark_mode",
  "colors": {
    "primary_gold": "#dfba73",
    "secondary_gold": "#cbba53",
    "background": "#080808",
    "black": "#000000",
    "glass": "rgba(255, 255, 255, 0.05)",
    "border": "rgba(223, 186, 115, 0.25)",
    "text_primary": "#ffffff",
    "text_secondary": "#9ca3af",
    "text_muted": "#6b7280"
  },
  "typography": {
    "font_family": "IBM Plex Sans Arabic, Alexandria, ui-sans-serif, system-ui, sans-serif",
    "font_sizes": {
      "xs": "10px",
      "sm": "12px",
      "base": "14px",
      "lg": "16px",
      "xl": "18px",
      "2xl": "24px"
    },
    "font_weights": {
      "light": 300,
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "components": {
    "glass_panel": {
      "background": "rgba(255, 255, 255, 0.03)",
      "backdrop_filter": "blur(20px)",
      "border": "1px solid rgba(223, 186, 115, 0.15)",
      "border_radius": "24px"
    },
    "buttons": {
      "gold_button": {
        "background": "linear-gradient(135deg, #dfba73 0%, #b89146 100%)",
        "color": "#000000",
        "border": "1px solid #dfba73",
        "font_weight": 500,
        "letter_spacing": "0.02em"
      },
      "gold_outline": {
        "background": "transparent",
        "color": "#dfba73",
        "border": "1px solid rgba(223, 186, 115, 0.4)"
      }
    },
    "cards": {
      "border_radius": "24px",
      "border": "1px solid rgba(223, 186, 115, 0.1)",
      "hover_border": "rgba(223, 186, 115, 0.25)",
      "shadow": "0 10px 30px rgba(0, 0, 0, 0.3)"
    }
  },
  "animations": {
    "transition_duration": "0.5s",
    "transition_easing": "cubic-bezier(0.16, 1, 0.3, 1)",
    "hover_lift": "-6px",
    "fade_in": {
      "opacity": [0, 1],
      "y": [25, 0]
    }
  },
  "scrollbar": {
    "width": "6px",
    "track": "#000000",
    "thumb": "#dfba73",
    "thumb_hover": "#cbba53"
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px"
  },
  "mobile": {
    "max_width": "768px",
    "font_scale": 0.9,
    "padding_reduction": 0.8,
    "touch_targets": {
      "min_size": "44px"
    }
  }
}
