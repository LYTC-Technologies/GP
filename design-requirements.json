{
  "theme": "premium_luxury_hotel",
  "colors": {
    "primary_gold": "#C9A35B",
    "secondary_gold": "#B88A44",
    "accent_gold": "#D6B574",
    "background": "#F7F5F1",
    "secondary_background": "#F2EEE8",
    "card_background": "rgba(255,255,255,0.75)",
    "glass": "rgba(255,255,255,0.65)",
    "border": "rgba(201,163,91,0.20)",
    "text_primary": "#171717",
    "text_secondary": "#555555",
    "text_muted": "#8A8A8A",
    "success": "#3F8C5A",
    "danger": "#B64545"
  },
  "typography": {
    "font_family": "IBM Plex Sans Arabic, Alexandria, ui-sans-serif, system-ui, sans-serif",
    "font_sizes": {
      "xs": "10px",
      "sm": "12px",
      "base": "14px",
      "lg": "16px",
      "xl": "18px",
      "2xl": "24px"
    },
    "font_weights": {
      "light": 300,
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "components": {
    "glass_panel": {
      "background": "rgba(255,255,255,0.65)",
      "backdrop_filter": "blur(20px)",
      "border": "1px solid rgba(201,163,91,0.15)",
      "border_radius": "24px"
    },
    "buttons": {
      "gold_button": {
        "background": "linear-gradient(135deg, #D6B574 0%, #B88A44 100%)",
        "color": "#111111",
        "border": "1px solid #C9A35B",
        "font_weight": 500,
        "letter_spacing": "0.02em",
        "hover_scale": "1.02"
      },
      "gold_outline": {
        "background": "transparent",
        "color": "#C9A35B",
        "border": "1px solid rgba(201,163,91,0.4)",
        "hover_background": "rgba(201,163,91,0.08)"
      }
    },
    "cards": {
      "border_radius": "24px",
      "border": "1px solid rgba(201,163,91,0.18)",
      "hover_border": "rgba(201,163,91,0.25)",
      "shadow": "0 12px 30px rgba(0,0,0,0.08)"
    },
    "inputs": {
      "background": "rgba(255,255,255,0.8)",
      "border": "rgba(201,163,91,0.2)",
      "placeholder": "#8A8A8A",
      "focus_border": "#C9A35B"
    }
  },
  "animations": {
    "transition_duration": "0.5s",
    "transition_easing": "cubic-bezier(0.16, 1, 0.3, 1)",
    "hover_lift": "-6px",
    "fade_in": {
      "opacity": [0, 1],
      "y": [25, 0]
    }
  },
  "scrollbar": {
    "width": "6px",
    "track": "#EEEAE4",
    "thumb": "#C9A35B",
    "thumb_hover": "#B88A44"
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px"
  },
  "mobile": {
    "max_width": "768px",
    "font_scale": 0.9,
    "padding_reduction": 0.8,
    "touch_targets": {
      "min_size": "44px"
    }
  }
}
